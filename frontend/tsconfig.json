{
  "compilerOptions": {
    "target": "es2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      },
      {
        "name": "typescript-plugin-tw-template"
      }
    ],
    "paths": {
      "@/*": [
        "./src/scripts/*"
      ],
      "@definitions/*": [
        "./src/scripts/api/definitions/*"
      ],
      "@feature/*": [
        "./src/scripts/components/server/features/*"
      ]
    }
  },
  "include": [
    "app/**/*",
    "next-env.d.ts",
    "src/**/*",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
